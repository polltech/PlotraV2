# ── Kipawa Platform / Plotra Platform - Environment Variables ─────────────────
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Application ─────────────────────────────────────────────────────────────────
PLOTRA_APP__NAME=Kipawa Platform
PLOTRA_APP__VERSION=1.0.0
PLOTRA_APP__DEBUG=true
PLOTRA_APP__ENV=development
PLOTRA_APP__SECRET_KEY=change-this-to-a-long-random-string-min-32-chars-here
PLOTRA_APP__ALGORITHM=HS256
PLOTRA_APP__ACCESS_TOKEN_EXPIRE_MINUTES=60
PLOTRA_APP__FRONTEND_BASE_URL=http://localhost:8080

# ── Database ─────────────────────────────────────────────────────────────────────────────
PLOTRA_DATABASE__HOST=localhost
PLOTRA_DATABASE__PORT=5432
PLOTRA_DATABASE__USERNAME=postgres
PLOTRA_DATABASE__PASSWORD=change_me_in_production
PLOTRA_DATABASE__NAME=plotra_db
PLOTRA_DATABASE__POOL_SIZE=10
PLOTRA_DATABASE__MAX_OVERFLOW=20
PLOTRA_DATABASE__ASYNC_MODE=true

# ── Redis ───────────────────────────────────────────────────────────────────────────────
PLOTRA_REDIS__HOST=localhost
PLOTRA_REDIS__PORT=6379
PLOTRA_REDIS__DB=0

# ── PostGIS / Geospatial ──────────────────────────────────────────────────────────────
PLOTRA_POSTGIS__ENABLED=true
PLOTRA_POSTGIS__SRID=4326
PLOTRA_GEOSPATIAL__GPS_ACCURACY_THRESHOLD_METERS=10
PLOTRA_GEOSPATIAL__MIN_POLYGON_AREA_HECTARES=0.1
PLOTRA_GEOSPATIAL__MAX_FARM_POLYGONS_PER_FARMER=10
PLOTRA_GEOSPATIAL__PARENT_CHILD_VALIDATION=true
PLOTRA_GEOSPATIAL__BOUNDARY_OVERLAP_TOLERANCE=0.01

# ── Satellite / GEE ─────────────────────────────────────────────────────────────────
PLOTRA_SATELLITE__PROVIDER=sentinel_hub
PLOTRA_SATELLITE__API_KEY=your_sentinel_hub_or_gee_key
PLOTRA_SATELLITE__BASE_URL=https://services.sentinel-hub.com
PLOTRA_SATELLITE__SIMULATION_MODE=true
PLOTRA_SATELLITE__NDVI_THRESHOLD=0.65
PLOTRA_SATELLITE__DEFORESTATION_BASELINE_YEAR=2014
PLOTRA_SATELLITE__BIOMASS_THRESHOLD=100.0

# ── EUDR Compliance ─────────────────────────────────────────────────────────────────
PLOTRA_EUDR__COMPLIANCE_STATUS=Under Review
PLOTRA_EUDR__CERTIFICATE_VALIDITY_DAYS=365
PLOTRA_EUDR__DDS_VERSION=1.0
PLOTRA_EUDR__PORTAL_URL=https://eudr-portal.example.com

# ── Email ───────────────────────────────────────────────────────────────────────────────
PLOTRA_EMAIL__SMTP_SERVER=mail.yourdomain.com
PLOTRA_EMAIL__SMTP_PORT=587
PLOTRA_EMAIL__SMTP_USERNAME=plotra@yourdomain.com
PLOTRA_EMAIL__SMTP_PASSWORD=your_smtp_password
PLOTRA_EMAIL__FROM_EMAIL=plotra@yourdomain.com
PLOTRA_EMAIL__FROM_NAME=Plotra Platform
PLOTRA_EMAIL__USE_TLS=true
PLOTRA_EMAIL__DEBUG_MODE=false

# ── Authentication ──────────────────────────────────────────────────────────────────
PLOTRA_AUTH__MAX_LOGIN_ATTEMPTS=5
PLOTRA_AUTH__LOCKOUT_DURATION_MINUTES=15
PLOTRA_AUTH__PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# ── CORS ───────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
PLOTRA_CORS__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# ── Storage / S3 ────────────────────────────────────────────────────────────────────
PLOTRA_STORAGE__DOCUMENTS_PATH=./uploads/documents
PLOTRA_STORAGE__CERTIFICATES_PATH=./uploads/certificates
PLOTRA_STORAGE__PHOTOS_PATH=./uploads/photos
PLOTRA_STORAGE__S3_BUCKET=plotra-uploads
PLOTRA_STORAGE__S3_ENDPOINT=https://s3.your-provider.com
PLOTRA_STORAGE__S3_ACCESS_KEY=your_access_key
PLOTRA_STORAGE__S3_SECRET_KEY=your_secret_key
PLOTRA_STORAGE__S3_REGION=af-south-1

# ── Celery / Workers ──────────────────────────────────────────────────────────────────
PLOTRA_CELERY__BROKER_URL=redis://localhost:6379/1
PLOTRA_CELERY__RESULT_BACKEND=redis://localhost:6379/2

# ── Payments ───────────────────────────────────────────────────────────────────────────
PLOTRA_PAYMENTS__ENABLED=false
PLOTRA_PAYMENTS__MPESA_CONSUMER_KEY=
PLOTRA_PAYMENTS__MPESA_CONSUMER_SECRET=
PLOTRA_PAYMENTS__MPESA_SHORTCODE=
PLOTRA_PAYMENTS__ESCROW_ENABLED=true

# ── Verification ───────────────────────────────────────────────────────────────────
PLOTRA_VERIFICATION__REQUIRE_ALL_FIELDS=false
PLOTRA_VERIFICATION__AUTO_SUBMIT_EUDR=false
PLOTRA_VERIFICATION__ALERT_THRESHOLD_DAYS=30

# ── Logging ──────────────────────────────────────────────────────────────────────────
PLOTRA_LOGGING__LEVEL=INFO
PLOTRA_LOGGING__FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
PLOTRA_LOGGING__FILE=logs/plotra.log
PLOTRA_LOGGING__AUDIT_ENABLED=true

# ── Kipawa Platform Specific ──────────────────────────────────────────────────────
# GPS Tolerance (meters) - 3-5m per spec
PLOTRA_GPS_TOLERANCE_METERS=3.0

# NDVI Heritage Slope Period (years)
PLOTRA_HERITAGE_START_YEAR=2015
PLOTRA_HERITAGE_END_YEAR=2020

# EUDR Baseline Date (forest cover as of)
PLOTRA_EUDR_BASELINE_DATE=2020-12-31

# False Positive Rate Threshold (%)
PLOTRA_FALSE_POSITIVE_THRESHOLD=5

# Conflict Resolution SLA (hours)
PLOTRA_CONFLICT_SLA_HOURS=48

# Polygon Validation Latency (seconds)
PLOTRA_POLYGON_VALIDATION_MAX_SECONDS=2

# Sync Success Rate Threshold (%)
PLOTRA_SYNC_SUCCESS_THRESHOLD=99.5

# ── Production Deployment ───────────────────────────────────────────────────────────
UVICORN_WORKERS=2